{
	// Start from Pyright's recommended rules
	"typeCheckingMode": "standard",
	// Virtual environment configuration
	"venvPath": ".",
	"venv": ".venv",
	// Then override specific settings. I don't think this overwrite really works..
	"failOnWarnings": false,
	"reportMissingTypeStubs": "none",
	"reportExplicitAny": "none",
	"reportAny": "none",
	"reportAssignmentType": "none",
	"ignore": [
		"src/usigrabber/utils/uuid.py",
		"experimental/*",
	]
}
