          },
          "editorMode": "code",
          "format": "table",
          "hide": true,
          "rawQuery": true,
          "rawSql": "WITH stats AS (\n  SELECT \n    measured_at, \n    row_count,\n    LAG(row_count) OVER (ORDER BY measured_at) as prev_count,\n    LAG(measured_at) OVER (ORDER BY measured_at) as prev_time\n  FROM psm_growth_stats\n  ORDER BY measured_at DESC\n  LIMIT 1\n)\nSELECT \n  measured_at,\n  (row_count - prev_count) / (EXTRACT(EPOCH FROM (measured_at - prev_time)) / 60) AS growth_per_minute\nFROM stats;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
