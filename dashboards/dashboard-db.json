          "rawQuery": true,
          "rawSql": "SELECT EXTRACT(EPOCH FROM (MAX(measured_at) - MIN(measured_at))) / 60 \nFROM (SELECT measured_at FROM psm_growth_stats ORDER BY measured_at DESC LIMIT 2) AS recent;",
          "refId": "timedelta",
